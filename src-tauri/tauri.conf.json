{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VibeToText",
  "version": "0.1.1",
  "identifier": "dev.vibetotext.app",
  "build": {
    "frontendDist": "../src",
    "beforeBundleCommand": "npm run stage-bundle-resources"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "settings",
        "title": "VibeToText — Dashboard",
        "url": "index.html",
        "width": 920,
        "height": 800,
        "minWidth": 720,
        "minHeight": 600,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "skipTaskbar": false,
        "alwaysOnTop": false,
        "transparent": false,
        "backgroundColor": "#0b0c10",
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --enable-features=OverlayScrollbar,msOverlayScrollbarWinStyle,msOverlayScrollbarWinStyleAnimation"
      },
      {
        "label": "overlay",
        "title": "VibeToText — Listening",
        "url": "overlay.html",
        "width": 460,
        "height": 130,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": false,
        "focus": false,
        "acceptFirstMouse": false,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --enable-features=OverlayScrollbar,msOverlayScrollbarWinStyle,msOverlayScrollbarWinStyleAnimation"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "bundle-resources/sherpa-onnx-c-api.dll": "./sherpa-onnx-c-api.dll",
      "bundle-resources/sherpa-onnx-cxx-api.dll": "./sherpa-onnx-cxx-api.dll",
      "bundle-resources/onnxruntime.dll": "./onnxruntime.dll",
      "bundle-resources/onnxruntime_providers_shared.dll": "./onnxruntime_providers_shared.dll"
    },
    "category": "Productivity",
    "shortDescription": "Local push-to-talk dictation",
    "longDescription": "VibeToText captures your voice via a global hotkey and pastes the transcript wherever your cursor is. 100% on-device — Whisper (CTranslate2, GPU/CPU) + Moonshine base-en (sherpa-onnx, CPU).",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "files": {
        "MacOS/libsherpa-onnx-c-api.dylib": "bundle-resources/libsherpa-onnx-c-api.dylib",
        "MacOS/libsherpa-onnx-cxx-api.dylib": "bundle-resources/libsherpa-onnx-cxx-api.dylib",
        "MacOS/libonnxruntime.dylib": "bundle-resources/libonnxruntime.dylib",
        "MacOS/libonnxruntime.1.24.4.dylib": "bundle-resources/libonnxruntime.1.24.4.dylib"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  }
}
